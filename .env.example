TSNET_ENABLED=true
TSNET_HOSTNAME=aperture-langfuse-relay
TSNET_STATE_DIR=./.tsnet
# Optional but recommended for headless/container deploys.
TS_AUTHKEY=

LISTEN_ADDR=:8080
WEBHOOK_PATH=/hooks/aperture

# Optional. If set, incoming webhooks must match this key.
APERTURE_API_KEY=

LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_ENV=production

REQUEST_TIMEOUT=15s
SHUTDOWN_TIMEOUT=10s
MAX_REQUEST_BODY_BYTES=4194304
