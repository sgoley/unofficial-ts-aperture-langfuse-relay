TSNET_ENABLED=true
TSNET_TLS_ENABLED=false
TSNET_HOSTNAME=aperture-langfuse-relay
# Local default for `go run .`; for Docker/systemd use a persistent absolute path.
TSNET_STATE_DIR=./.tsnet
# Optional but recommended for headless/container deploys.
TS_AUTHKEY=

# Arbitrary app port. Must match the URL you configure in Aperture hooks.
LISTEN_ADDR=:8080
WEBHOOK_PATH=/hooks/aperture

# Optional. If set, incoming webhooks must match this key.
APERTURE_API_KEY=

LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_ENV=production

REQUEST_TIMEOUT=5s
SHUTDOWN_TIMEOUT=10s
MAX_REQUEST_BODY_BYTES=3145728
MAX_LANGFUSE_BATCH_BYTES=3145728
QUEUE_SIZE=100
WORKER_COUNT=2
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=250ms
RETRY_MAX_DELAY=5s
